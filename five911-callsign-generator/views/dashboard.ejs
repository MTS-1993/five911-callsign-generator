<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Five911 Callsign Admin</title>
  <style>
    :root{--bg:#070b14;--panel:rgba(15,23,42,.92);--card:rgba(17,24,39,.86);--text:#f8fafc;--muted:#94a3b8;--line:rgba(148,163,184,.18);--accent:#ef4444;--blue:#2563eb;--green:#22c55e;--yellow:#f59e0b;--shadow:0 24px 90px rgba(0,0,0,.42)}
    *{box-sizing:border-box} body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--text);background:radial-gradient(circle at 15% 0%,rgba(239,68,68,.28),transparent 30%),radial-gradient(circle at 85% 10%,rgba(37,99,235,.25),transparent 32%),linear-gradient(135deg,#050816 0%,#0b1020 52%,#111827 100%);min-height:100vh}.wrap{width:min(1320px,calc(100% - 36px));margin:0 auto;padding:34px 0}.topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:22px}.brand{display:flex;align-items:center;gap:12px}.badge-logo{width:46px;height:46px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--blue));box-shadow:0 12px 30px rgba(239,68,68,.22);font-weight:900}.brand small{display:block;color:var(--muted);margin-top:2px}.top-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap}.pill{border:1px solid var(--line);background:rgba(15,23,42,.72);color:var(--muted);padding:10px 14px;border-radius:999px;font-size:14px}.linkbtn,.dangerbtn,.savebtn,.editbtn{border:0;text-decoration:none;color:white;padding:10px 14px;border-radius:14px;font-weight:900;cursor:pointer;display:inline-flex;align-items:center;justify-content:center}.linkbtn{background:linear-gradient(135deg,var(--accent),#b91c1c)}.dangerbtn{background:rgba(239,68,68,.18);color:#fecaca;border:1px solid rgba(239,68,68,.35)}.savebtn{background:linear-gradient(135deg,var(--green),#15803d)}.editbtn{background:rgba(37,99,235,.18);color:#bfdbfe;border:1px solid rgba(37,99,235,.35)}.hero{padding:30px;border:1px solid var(--line);background:linear-gradient(135deg,rgba(15,23,42,.94),rgba(17,24,39,.82));border-radius:28px;box-shadow:var(--shadow);display:grid;grid-template-columns:1fr auto;gap:20px;align-items:end}.eyebrow{color:#fecaca;text-transform:uppercase;letter-spacing:.18em;font-size:12px;font-weight:900;margin:0 0 10px}h1{font-size:clamp(34px,5vw,58px);line-height:1;margin:0;letter-spacing:-.055em}.muted{color:var(--muted);margin:14px 0 0;font-size:16px;max-width:760px}.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:16px;margin:18px 0}.card{padding:20px;background:var(--card);border:1px solid var(--line);border-radius:22px;backdrop-filter:blur(8px)}.card span{display:block;color:var(--muted);font-size:13px;text-transform:uppercase;letter-spacing:.08em;font-weight:800;margin-bottom:10px}.card strong{font-size:38px;letter-spacing:-.04em}.grid{display:grid;grid-template-columns:380px 1fr;gap:18px;align-items:start}.panel{background:var(--panel);border:1px solid var(--line);border-radius:28px;overflow:hidden;box-shadow:var(--shadow)}.panel-head{display:flex;align-items:center;justify-content:space-between;gap:18px;padding:22px;border-bottom:1px solid var(--line);background:rgba(15,23,42,.55)}h2{margin:0;font-size:22px;letter-spacing:-.03em}.form{padding:22px}.field{margin-bottom:14px}label{display:block;color:#cbd5e1;font-weight:800;font-size:13px;margin-bottom:7px}input,select{width:100%;padding:12px 13px;background:#020617;color:var(--text);border:1px solid var(--line);border-radius:14px;outline:none}input:focus,select:focus{border-color:rgba(239,68,68,.75);box-shadow:0 0 0 4px rgba(239,68,68,.12)}.search{width:min(430px,100%)}.alert{padding:13px 15px;border-radius:16px;margin:18px 0;border:1px solid}.alert.success{border-color:rgba(34,197,94,.35);background:rgba(34,197,94,.12);color:#bbf7d0}.alert.error{border-color:rgba(239,68,68,.35);background:rgba(239,68,68,.12);color:#fecaca}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse;min-width:980px}th,td{text-align:left;padding:15px 18px;border-bottom:1px solid var(--line);white-space:nowrap;vertical-align:middle}th{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.09em;background:rgba(2,6,23,.35)}tr:hover td{background:rgba(239,68,68,.07)}.callsign{display:inline-flex;padding:6px 10px;border-radius:999px;background:rgba(239,68,68,.14);color:#fecaca;font-weight:900;border:1px solid rgba(239,68,68,.26)}.actions{display:flex;gap:8px}.empty{padding:36px;text-align:center;color:var(--muted)}dialog{border:1px solid var(--line);border-radius:24px;background:#0f172a;color:var(--text);width:min(560px,calc(100% - 32px));box-shadow:0 30px 100px rgba(0,0,0,.6)}dialog::backdrop{background:rgba(2,6,23,.72)}.dialog-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}.x{background:transparent;border:1px solid var(--line);color:var(--text);border-radius:12px;padding:8px 10px;cursor:pointer}@media(max-width:980px){.grid{grid-template-columns:1fr}.hero{grid-template-columns:1fr}.topbar,.panel-head{flex-direction:column;align-items:flex-start}}
  </style>
</head>
<body>
  <main class="wrap">
    <div class="topbar">
      <div class="brand"><div class="badge-logo">911</div><div><strong>Five911</strong><small>Callsign Admin Dashboard</small></div></div>
      <div class="top-actions"><div class="pill">Logged in as <%= adminUsername %></div><form method="post" action="/logout"><button class="dangerbtn" type="submit">Logout</button></form></div>
    </div>

    <section class="hero">
      <div><p class="eyebrow">Five911 Operations</p><h1>Callsign Management</h1><p class="muted">Add, edit and delete callsigns directly from the dashboard. Discord allocations remain stored against the player’s Discord user ID.</p></div>
    </section>

    <% if (success) { %><div class="alert success"><%= success %></div><% } %>
    <% if (error) { %><div class="alert error"><%= error %></div><% } %>

    <section class="stats">
      <% Object.entries(stats).forEach(([dept,count]) => { %><article class="card"><span><%= dept %></span><strong><%= count %></strong></article><% }) %>
      <% if (!Object.keys(stats).length) { %><article class="card"><span>Total Allocated</span><strong>0</strong></article><article class="card"><span>Status</span><strong>Live</strong></article><% } %>
    </section>

    <section class="grid">
      <aside class="panel">
        <div class="panel-head"><div><h2>Add Callsign</h2><p class="muted" style="margin-top:6px;font-size:14px">Manual admin allocation.</p></div></div>
        <form class="form" method="post" action="/admin/callsigns">
          <div class="field"><label>Discord User ID</label><input name="discord_user_id" placeholder="Example: 123456789012345678" required></div>
          <div class="field"><label>Discord Username</label><input name="discord_username" placeholder="Example: Max#0001 or Max"></div>
          <div class="field"><label>Department</label><select name="department" class="dept-select" required><% Object.entries(config).forEach(([code,dept]) => { %><option value="<%= code %>"><%= dept.label %></option><% }) %></select></div>
          <div class="field"><label>Unit Type</label><select name="unit_type" class="unit-select" required></select></div>
          <div class="field"><label>Callsign</label><input name="callsign" placeholder="Example: 07123" required></div>
          <button class="savebtn" type="submit" style="width:100%;padding:13px 16px">Add Callsign</button>
        </form>
      </aside>

      <section class="panel">
        <div class="panel-head"><div><h2>Allocated Callsigns</h2><p class="muted" style="margin-top:6px;font-size:14px">Search by callsign, player, department or unit type.</p></div><input class="search" id="search" placeholder="Search callsign, user or department..."></div>
        <div class="table-wrap"><table id="callsignTable"><thead><tr><th>ID</th><th>Callsign</th><th>Player</th><th>Discord User ID</th><th>Department</th><th>Unit Type</th><th>Allocated</th><th>Actions</th></tr></thead><tbody>
          <% rows.forEach((row) => { %>
            <tr data-id="<%= row.id %>" data-discord-user-id="<%= row.discord_user_id %>" data-discord-username="<%= row.discord_username || '' %>" data-department="<%= row.department %>" data-unit-type="<%= row.unit_type %>" data-callsign="<%= row.callsign %>">
              <td>#<%= row.id %></td><td><span class="callsign"><%= row.callsign %></span></td><td><%= row.discord_username || 'Unknown' %></td><td><%= row.discord_user_id %></td><td><%= friendlyDepartment(row.department) %></td><td><%= friendlyUnit(row.department,row.unit_type) %></td><td><%= new Date(row.created_at).toLocaleString('en-GB') %></td>
              <td><div class="actions"><button class="editbtn" type="button" onclick="openEdit(this.closest('tr'))">Edit</button><form method="post" action="/admin/callsigns/<%= row.id %>/delete" onsubmit="return confirm('Delete callsign <%= row.callsign %>?')"><button class="dangerbtn" type="submit">Delete</button></form></div></td>
            </tr>
          <% }) %>
        </tbody></table><% if (!rows.length) { %><div class="empty">No callsigns allocated yet.</div><% } %></div>
      </section>
    </section>
  </main>

  <dialog id="editDialog">
    <form method="post" id="editForm">
      <div class="dialog-head"><h2>Edit Callsign</h2><button class="x" type="button" onclick="editDialog.close()">✕</button></div>
      <div class="field"><label>Discord User ID</label><input name="discord_user_id" id="edit_discord_user_id" required></div>
      <div class="field"><label>Discord Username</label><input name="discord_username" id="edit_discord_username"></div>
      <div class="field"><label>Department</label><select name="department" id="edit_department" class="dept-select" required><% Object.entries(config).forEach(([code,dept]) => { %><option value="<%= code %>"><%= dept.label %></option><% }) %></select></div>
      <div class="field"><label>Unit Type</label><select name="unit_type" id="edit_unit_type" class="unit-select" required></select></div>
      <div class="field"><label>Callsign</label><input name="callsign" id="edit_callsign" required></div>
      <button class="savebtn" type="submit" style="width:100%;padding:13px 16px">Save Changes</button>
    </form>
  </dialog>

  <script>
    const CONFIG = <%- JSON.stringify(config) %>;
    function fillUnits(deptSelect, unitSelect, selected) {
      const dept = deptSelect.value;
      unitSelect.innerHTML = '';
      Object.entries(CONFIG[dept]?.unitTypes || {}).forEach(([value, unit]) => {
        const opt = document.createElement('option'); opt.value = value; opt.textContent = unit.label; if (value === selected) opt.selected = true; unitSelect.appendChild(opt);
      });
    }
    document.querySelectorAll('.dept-select').forEach((deptSelect) => {
      const form = deptSelect.closest('form'); const unitSelect = form.querySelector('.unit-select'); fillUnits(deptSelect, unitSelect); deptSelect.addEventListener('change', () => fillUnits(deptSelect, unitSelect));
    });
    const search = document.getElementById('search'); const rows = [...document.querySelectorAll('#callsignTable tbody tr')];
    search?.addEventListener('input', () => { const q = search.value.toLowerCase(); rows.forEach(row => row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none'); });
    function openEdit(row) {
      const d = row.dataset; editForm.action = `/admin/callsigns/${d.id}/edit`; edit_discord_user_id.value = d.discordUserId || ''; edit_discord_username.value = d.discordUsername || ''; edit_department.value = d.department; fillUnits(edit_department, edit_unit_type, d.unitType); edit_callsign.value = d.callsign || ''; editDialog.showModal();
    }
  </script>
</body>
</html>
