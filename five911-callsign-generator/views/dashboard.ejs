<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Five911 Callsign Generator</title>
  <style>
    :root {
      --bg: #070b14;
      --panel: rgba(15, 23, 42, 0.92);
      --panel-2: rgba(30, 41, 59, 0.9);
      --card: rgba(17, 24, 39, 0.86);
      --text: #f8fafc;
      --muted: #94a3b8;
      --line: rgba(148, 163, 184, 0.18);
      --accent: #ef4444;
      --accent-2: #2563eb;
      --green: #22c55e;
      --shadow: 0 24px 90px rgba(0,0,0,.42);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at 15% 0%, rgba(239,68,68,.28), transparent 30%),
        radial-gradient(circle at 85% 10%, rgba(37,99,235,.25), transparent 32%),
        linear-gradient(135deg, #050816 0%, #0b1020 52%, #111827 100%);
      min-height: 100vh;
    }
    .wrap { width: min(1240px, calc(100% - 36px)); margin: 0 auto; padding: 34px 0; }
    .topbar { display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom: 22px; }
    .brand { display:flex; align-items:center; gap:12px; }
    .badge-logo { width:46px; height:46px; border-radius:16px; display:grid; place-items:center; background: linear-gradient(135deg, var(--accent), var(--accent-2)); box-shadow: 0 12px 30px rgba(239,68,68,.22); font-weight:900; }
    .brand small { display:block; color:var(--muted); margin-top:2px; }
    .pill { border:1px solid var(--line); background:rgba(15,23,42,.72); color:var(--muted); padding:10px 14px; border-radius:999px; font-size:14px; }
    .hero { padding:30px; border:1px solid var(--line); background: linear-gradient(135deg, rgba(15,23,42,.94), rgba(17,24,39,.82)); border-radius:28px; box-shadow: var(--shadow); display:grid; grid-template-columns: 1fr auto; gap:20px; align-items:end; }
    .eyebrow { color:#fecaca; text-transform:uppercase; letter-spacing:.18em; font-size:12px; font-weight:900; margin:0 0 10px; }
    h1 { font-size: clamp(34px, 5vw, 62px); line-height:1; margin:0; letter-spacing:-.055em; }
    .muted { color: var(--muted); margin:14px 0 0; font-size:16px; max-width:720px; }
    .button { display:inline-flex; align-items:center; gap:8px; color:white; background:linear-gradient(135deg, var(--accent), #b91c1c); padding:13px 17px; border-radius:16px; text-decoration:none; font-weight:800; box-shadow: 0 16px 28px rgba(239,68,68,.2); }
    .stats { display:grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap:16px; margin:18px 0; }
    .card { padding:20px; background:var(--card); border:1px solid var(--line); border-radius:22px; backdrop-filter: blur(8px); }
    .card span { display:block; color:var(--muted); font-size:13px; text-transform:uppercase; letter-spacing:.08em; font-weight:800; margin-bottom:10px; }
    .card strong { font-size:38px; letter-spacing:-.04em; }
    .panel { background:var(--panel); border:1px solid var(--line); border-radius:28px; overflow:hidden; box-shadow: var(--shadow); }
    .panel-head { display:flex; align-items:center; justify-content:space-between; gap:18px; padding:22px; border-bottom:1px solid var(--line); background:rgba(15,23,42,.55); }
    h2 { margin:0; font-size:22px; letter-spacing:-.03em; }
    .search { width:min(430px, 100%); padding:13px 16px; background:#020617; color:var(--text); border:1px solid var(--line); border-radius:16px; outline:none; font-size:14px; }
    .search:focus { border-color: rgba(239,68,68,.75); box-shadow: 0 0 0 4px rgba(239,68,68,.12); }
    .table-wrap { overflow:auto; }
    table { width:100%; border-collapse:collapse; min-width:860px; }
    th, td { text-align:left; padding:15px 18px; border-bottom:1px solid var(--line); white-space:nowrap; }
    th { color:var(--muted); font-size:12px; text-transform:uppercase; letter-spacing:.09em; background:rgba(2,6,23,.35); }
    tr:hover td { background:rgba(239,68,68,.07); }
    .callsign { display:inline-flex; padding:6px 10px; border-radius:999px; background:rgba(239,68,68,.14); color:#fecaca; font-weight:900; border:1px solid rgba(239,68,68,.26); }
    .empty { padding:36px; text-align:center; color:var(--muted); }
    @media (max-width: 720px) { .topbar, .hero, .panel-head { grid-template-columns:1fr; flex-direction:column; align-items:flex-start; } .hero { padding:24px; } }
  </style>
</head>
<body>
  <main class="wrap">
    <div class="topbar">
      <div class="brand">
        <div class="badge-logo">911</div>
        <div><strong>Five911</strong><small>Callsign Management</small></div>
      </div>
      <div class="pill">Discord Bot Connected</div>
    </div>

    <section class="hero">
      <div>
        <p class="eyebrow">Five911 Operations</p>
        <h1>Callsign Generator</h1>
        <p class="muted">Discord-allocated callsigns stored against each player, with live department totals and searchable allocation history.</p>
      </div>
      <a class="button" href="/api/callsigns<%= dashboardKey ? '?key=' + dashboardKey : '' %>">View API</a>
    </section>

    <section class="stats">
      <% Object.entries(stats).forEach(([dept, count]) => { %>
        <article class="card">
          <span><%= dept %></span>
          <strong><%= count %></strong>
        </article>
      <% }) %>
      <% if (!Object.keys(stats).length) { %>
        <article class="card"><span>Total Allocated</span><strong>0</strong></article>
        <article class="card"><span>Status</span><strong>Live</strong></article>
      <% } %>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <h2>Allocated Callsigns</h2>
          <p class="muted" style="margin-top:6px;font-size:14px;">Search by callsign, player, department or unit type.</p>
        </div>
        <input class="search" id="search" placeholder="Search callsign, user or department..." />
      </div>
      <div class="table-wrap">
        <table id="callsignTable">
          <thead>
            <tr>
              <th>ID</th>
              <th>Callsign</th>
              <th>Player</th>
              <th>Department</th>
              <th>Unit Type</th>
              <th>Allocated</th>
            </tr>
          </thead>
          <tbody>
            <% rows.forEach((row) => { %>
              <tr>
                <td>#<%= row.id %></td>
                <td><span class="callsign"><%= row.callsign %></span></td>
                <td><%= row.discord_username || row.discord_id || row.discord_user_id %></td>
                <td><%= friendlyDepartment(row.department) %></td>
                <td><%= friendlyUnit(row.department, row.unit_type) %></td>
                <td><%= new Date(row.created_at).toLocaleString('en-GB') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <% if (!rows.length) { %>
          <div class="empty">No callsigns allocated yet. Once a player uses the Discord command, they will appear here.</div>
        <% } %>
      </div>
    </section>
  </main>
  <script>
    const search = document.getElementById('search');
    const rows = [...document.querySelectorAll('#callsignTable tbody tr')];
    search.addEventListener('input', () => {
      const q = search.value.toLowerCase();
      rows.forEach(row => row.style.display = row.innerText.toLowerCase().includes(q) ? '' : 'none');
    });
  </script>
</body>
</html>
