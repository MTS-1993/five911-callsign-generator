<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Five911 Admin Login</title>
  <style>
    :root { --bg:#070b14; --panel:rgba(15,23,42,.94); --text:#f8fafc; --muted:#94a3b8; --line:rgba(148,163,184,.18); --accent:#ef4444; --blue:#2563eb; }
    *{box-sizing:border-box} body{margin:0;min-height:100vh;display:grid;place-items:center;font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--text);background:radial-gradient(circle at 15% 0%,rgba(239,68,68,.28),transparent 30%),radial-gradient(circle at 85% 10%,rgba(37,99,235,.25),transparent 32%),linear-gradient(135deg,#050816 0%,#0b1020 52%,#111827 100%)}
    .card{width:min(430px,calc(100% - 32px));padding:30px;border:1px solid var(--line);background:var(--panel);border-radius:28px;box-shadow:0 24px 90px rgba(0,0,0,.42)}
    .logo{width:54px;height:54px;border-radius:18px;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--blue));font-weight:900;margin-bottom:18px}.eyebrow{color:#fecaca;text-transform:uppercase;letter-spacing:.18em;font-size:12px;font-weight:900;margin:0 0 8px}h1{margin:0;font-size:34px;letter-spacing:-.05em}.muted{color:var(--muted);line-height:1.55}label{display:block;margin:16px 0 7px;color:#cbd5e1;font-weight:800;font-size:13px}input{width:100%;padding:14px 15px;border-radius:15px;border:1px solid var(--line);background:#020617;color:var(--text);outline:none}input:focus{border-color:rgba(239,68,68,.75);box-shadow:0 0 0 4px rgba(239,68,68,.12)}button{width:100%;margin-top:20px;padding:14px 16px;border:0;border-radius:16px;color:white;background:linear-gradient(135deg,var(--accent),#b91c1c);font-weight:900;cursor:pointer}.alert{padding:12px 14px;border-radius:14px;margin-top:16px;border:1px solid rgba(239,68,68,.35);background:rgba(239,68,68,.12);color:#fecaca}.warn{border-color:rgba(251,191,36,.35);background:rgba(251,191,36,.12);color:#fde68a}
  </style>
</head>
<body>
  <form class="card" method="post" action="/login">
    <div class="logo">911</div>
    <p class="eyebrow">Five911 Admin</p>
    <h1>Dashboard Login</h1>
    <p class="muted">Sign in to manage player callsigns, add manual allocations, edit records or delete incorrect callsigns.</p>
    <% if (!configured) { %><div class="alert warn">ADMIN_PASSWORD is not set in Render. Add it before using the admin dashboard.</div><% } %>
    <% if (error) { %><div class="alert"><%= error %></div><% } %>
    <label>Username</label>
    <input name="username" autocomplete="username" placeholder="admin" required />
    <label>Password</label>
    <input name="password" type="password" autocomplete="current-password" required />
    <button type="submit">Login</button>
  </form>
</body>
</html>
